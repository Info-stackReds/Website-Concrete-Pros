<svg xmlns="http://www.w3.org/2000/svg" width="800" height="600" viewBox="0 0 800 600">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#546E7A"/>
      <stop offset="100%" style="stop-color:#102027"/>
    </linearGradient>
    <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
      <path d="M 40 0 L 0 0 0 40" fill="none" stroke="rgba(255,255,255,0.04)" stroke-width="1"/>
    </pattern>
    <linearGradient id="overlay" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:rgba(0,0,0,0)"/>
      <stop offset="100%" style="stop-color:rgba(0,0,0,0.5)"/>
    </linearGradient>
  </defs>
  <rect width="800" height="600" fill="url(#bg)"/>
  <rect width="800" height="600" fill="url(#grid)"/>
  <rect width="800" height="600" fill="url(#overlay)"/>
  <!-- Decorative elements -->
  <circle cx="120" cy="120" r="96" fill="rgba(193,39,45,0.08)"/>
  <circle cx="680" cy="480" r="120" fill="rgba(255,255,255,0.04)"/>
  <rect x="40" y="360" width="64" height="240" fill="rgba(193,39,45,0.15)"/>
  <rect x="696" y="0" width="64" height="210" fill="rgba(193,39,45,0.1)"/>
  <!-- Red accent bar -->
  <rect x="0" y="432" width="320" height="3" fill="#C1272D"/>
  <!-- Logo mark -->
  <rect x="40" y="60" width="4" height="72" fill="#C1272D"/>
  <!-- Title -->
  <text x="400" y="312" 
        font-family="Arial Black, sans-serif" font-size="33" font-weight="900"
        fill="white" text-anchor="middle" letter-spacing="4"
        style="text-transform:uppercase">SITTING WALLS</text>
  <!-- Subtitle -->
  <text x="400" y="372" 
        font-family="Arial, sans-serif" font-size="17" font-weight="400"
        fill="rgba(255,255,255,0.6)" text-anchor="middle" letter-spacing="2">Custom Concrete Walls</text>
  <!-- Bottom badge -->
  <rect x="320" y="468" width="160" height="32" rx="2" fill="#C1272D"/>
  <text x="400" y="489" 
        font-family="Arial, sans-serif" font-size="11" font-weight="700"
        fill="white" text-anchor="middle" letter-spacing="2">CONCRETE PROS IL</text>
</svg>