<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="700" viewBox="0 0 1200 700">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1A237E"/>
      <stop offset="100%" style="stop-color:#000051"/>
    </linearGradient>
    <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
      <path d="M 40 0 L 0 0 0 40" fill="none" stroke="rgba(255,255,255,0.04)" stroke-width="1"/>
    </pattern>
    <linearGradient id="overlay" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:rgba(0,0,0,0)"/>
      <stop offset="100%" style="stop-color:rgba(0,0,0,0.5)"/>
    </linearGradient>
  </defs>
  <rect width="1200" height="700" fill="url(#bg)"/>
  <rect width="1200" height="700" fill="url(#grid)"/>
  <rect width="1200" height="700" fill="url(#overlay)"/>
  <!-- Decorative elements -->
  <circle cx="180" cy="140" r="144" fill="rgba(193,39,45,0.08)"/>
  <circle cx="1020" cy="560" r="180" fill="rgba(255,255,255,0.04)"/>
  <rect x="60" y="420" width="96" height="280" fill="rgba(193,39,45,0.15)"/>
  <rect x="1044" y="0" width="96" height="244" fill="rgba(193,39,45,0.1)"/>
  <!-- Red accent bar -->
  <rect x="0" y="504" width="480" height="3" fill="#C1272D"/>
  <!-- Logo mark -->
  <rect x="60" y="70" width="4" height="84" fill="#C1272D"/>
  <!-- Title -->
  <text x="600" y="364" 
        font-family="Arial Black, sans-serif" font-size="50" font-weight="900"
        fill="white" text-anchor="middle" letter-spacing="4"
        style="text-transform:uppercase">YOUR HOME TRANSFORMED</text>
  <!-- Subtitle -->
  <text x="600" y="434" 
        font-family="Arial, sans-serif" font-size="26" font-weight="400"
        fill="rgba(255,255,255,0.6)" text-anchor="middle" letter-spacing="2">Crystal Lake, IL</text>
  <!-- Bottom badge -->
  <rect x="520" y="546" width="160" height="32" rx="2" fill="#C1272D"/>
  <text x="600" y="567" 
        font-family="Arial, sans-serif" font-size="11" font-weight="700"
        fill="white" text-anchor="middle" letter-spacing="2">CONCRETE PROS IL</text>
</svg>